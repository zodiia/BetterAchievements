{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "MainWindowLayout",
    "type": "object",
    "properties": {
        "achievementLayout": {
            "type": "array",
            "items": { "$ref": "#/$defs/achievementLayout" }
        }
    },
    "required": ["achievementLayout"],
    "$defs": {
        "achievementLayout": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": ["group", "category"]
                },
                "name": { "type": "string" }
            },
            "required": ["type", "name"],
            "oneOf": [
                {
                    "required": ["items"],
                    "properties": {
                        "type": { "const": "items" },
                        "groups": {
                            "type": "array",
                            "items": { "$ref": "#/$defs/achievementLayout" }
                        }
                    }
                },
                {
                    "required": ["items"],
                    "properties": {
                        "type": { "const": "category" },
                        "items": {
                            "type": "array",
                            "items": { "$ref": "#/$defs/achievementLayoutItem" }
                        }
                    }
                }
            ]
        },
        "achievementLayoutItem": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": ["simple", "tiered", "combined"]
                }
            },
            "required": ["type"],
            "oneOf": [
                {
                    "required": ["id"],
                    "properties": {
                        "type": { "const": "simple" },
                        "id": {
                            "type": "integer",
                            "minimum": 0
                        }
                    }
                },
                {
                    "required": ["ids"],
                    "properties": {
                        "type": { "const": "tiered" },
                        "ids": {
                            "type": "array",
                            "items": {
                                "type": "integer",
                                "minimum": 0
                            }
                        }
                    }
                },
                {
                    "required": ["ids"],
                    "properties": {
                        "type": { "const": "combined" },
                        "ids": {
                            "type": "array",
                            "items": {
                                "type": "integer",
                                "minimum": 0
                            }
                        }
                    }
                }
            ]
        }
    }
}
